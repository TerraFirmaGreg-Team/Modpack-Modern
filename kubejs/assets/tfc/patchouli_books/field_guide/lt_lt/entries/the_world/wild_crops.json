{
  "name": "Laukiniai pasėliai",
  "category": "tfc:the_world",
  "icon": "tfc:textures/gui/book/icons/wild_crops.png",
  "pages": [
    {
      "type": "patchouli:text",
      "text": "$(thing)Laukiniai pasėliai $() auga išsibarstyti po visą pasaulį, mažais lopinėliais. Jas galima nuimti maistui ir sėkloms, kurias vėliau galima auginti kaip kultivuotus pasėlius.$(br2)Laukinius pasėlius galima nuimti rankomis, $(thing)peiliu$() ar kitu aštriu įrankiu. Sunaikinus, jie išmes $(thing)sėklas$() ir keletą $(thing)produktų$()."
    },
    {
      "type": "patchouli:multiblock",
      "multiblock": {
        "pattern": [
          [
            "X"
          ],
          [
            "0"
          ]
        ],
        "mapping": {
          "X": "tfc:wild_crop/wheat[mature=true]"
        }
      },
      "name": "Laukiniai kviečiai",
      "text": "Laukinių pasėlių pavyzdys, šiuo atveju: $(l:mechanics/crops#wheat)Kviečiai$().",
      "enable_visualize": false
    },
    {
      "type": "patchouli:text",
      "text": "Kiekvienas $(l:mechanics/crops)pasėlis$(), kurį galima auginti, taip pat auga ir gamtoje. Laukiniai pasėliai atrodo panašiai kaip jų kultivuoti atitikmenys, tačiau yra labiau pasislėpę žolėje. Laukiniai pasėliai subręsta tik nuo birželio iki spalio. Kitais laikotarpiais jie atrodo nudžiūvę iki kitos vasaros."
    },
