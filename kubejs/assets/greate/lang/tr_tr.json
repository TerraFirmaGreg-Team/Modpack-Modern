  "greate.ponder.cogwheel_casing.text_1": "Pirinç veya Andezit Kasa, Dişlileri süslemek için kullanılabilir",
  "greate.ponder.cogwheel_casing.text_2": "Kaplandıktan sonra eklenen bileşenler şafta bağlanmaz",
  "greate.ponder.cogwheel_casing.text_3": "Ayarlı Anahtar, bağlantıları açıp kapatmak için kullanılabilir",
  "greate.ponder.crushing_wheels.header": "Malzemeleri Ezici Tekerler ile İşleme",
  "greate.ponder.crushing_wheels.text_1": "Bir çift Ezici Teker, malzemeleri oldukça verimli bir şekilde öğütebilir",
  "greate.ponder.crushing_wheels.text_2": "Dönme yönleri birbirine ters olacak şekilde ayarlanmalıdır",
  "greate.ponder.crushing_wheels.text_3": "Üst kısmına atılan veya yerleştirilen malzemeleri işler",
  "greate.ponder.crushing_wheels.text_4": "Eşyaların eklenmesi veya çıkarılması otomatikleştirilebilir",
  "greate.ponder.fan_direction.header": "Muhafazalı Fanların Hava Akışı",
  "greate.ponder.fan_direction.text_1": "Muhafazalı Fan, Hava Akımı oluşturmak için Dönme Kuvvetinden yararlanır",
  "greate.ponder.fan_direction.text_2": "Akış Gücü ve Yönü, Girişten Sağlanan Dönüşe bağlıdır",
  "greate.ponder.fan_processing.header": "Malzemeleri Muhafazalı Fan ile İşleme",
  "greate.ponder.fan_processing.text_1": "Hava Akışı lavın içerisinden geçerken Isınır",
  "greate.ponder.fan_processing.text_2": "Isınan havaya temas eden eşyalar eritilir",
  "greate.ponder.fan_processing.text_3": "Ama yiyecekler gibi eritilemeyen eşyalar yanar",
  "greate.ponder.fan_processing.text_4": "Bunun yerine yiyecekler için Ateş ile Tütsüleme yapılmalıdır",
  "greate.ponder.fan_processing.text_5": "Suyun içerisinden geçen Hava Akışı, bir Yıkama Düzeneği oluşturur",
  "greate.ponder.fan_processing.text_6": "Bu yöntemle bazı ilginç işlemler yapılabilir",
  "greate.ponder.fan_processing.text_7": "The Speed of the Fan DOES affect the processing speed, in addition to its range",
  "greate.ponder.fan_processing.text_8": "Kayış ve Depolarda bulunan Eşyalar da Fan ile İşlenebilir",
  "greate.ponder.gearbox.header": "Şanzıman ile Dönme Kuvveti Aktarımı",
  "greate.ponder.gearbox.text_1": "Dönme eksenleri arasında geçiş yapmak fazla yer kaplayabilir",
  "greate.ponder.gearbox.text_2": "Bir şanzıman bu düzeneğin daha az yer kaplayan eşdeğeridir",
  "greate.ponder.gearbox.text_3": "Köşelerin yanlarında olan şaftlar birbirinin ayna görüntüsü yönde döner",
  "greate.ponder.gearbox.text_4": "Düz bağlantılar ters yöne döner",
  "greate.ponder.large_cogwheel.header": "Büyük Dişliler Kullanarak Dönme Kuvveti Aktarma",
  "greate.ponder.large_cogwheel.text_1": "Büyük dişliler, dik açı yapacak şekilde birbirlerine bağlanabilir",
  "greate.ponder.large_cogwheel.text_2": "Hızın diğer dönme eksenlerine aktarılmasına yardım eder",
  "greate.ponder.mechanical_mixer.header": "Malzemeleri Mekanik Mikser ile İşleme",
  "greate.ponder.mechanical_mixer.text_1": "Bazı Üretim Tarifleri, Mikser ve Kazan ile otomatikleştirilebilir",
  "greate.ponder.mechanical_mixer.text_2": "Tüm Şekilsiz Üretim Tarifleri ve ek birkaç tarif daha mevcuttur",
  "greate.ponder.mechanical_mixer.text_3": "Tariflerin bazıları Blaze Ocağının sağladığı ısıyı gerektirir",
  "greate.ponder.mechanical_mixer.text_4": "İki farklı tarifin çakıştığı durumlarda filtre yuvası kullanılabilir.",
  "greate.ponder.mechanical_press_compacting.header": "Eşyaları Mekanik Pres ile Sıkıştırma",
  "greate.ponder.mechanical_press_compacting.text_1": "Kazandaki malzemeler, Pres ile bastırıldığında Sıkılaşır",
  "greate.ponder.mechanical_press_compacting.text_2": "Tüm dolu 2'ye 2 ve 3'e 3 Üretim Tarifleri ve ek birkaç tarif daha Sıkıştırma için mevcuttur",
  "greate.ponder.mechanical_press_compacting.text_3": "Tariflerin bazıları Blaze Ocağının sağladığı ısıyı gerektirir",
  "greate.ponder.mechanical_press_compacting.text_4": "İki farklı tarifin çakıştığı durumlarda filtre yuvası kullanılabilir.",
  "greate.ponder.mechanical_pump_flow.header": "Mekanik Pompa Kullanarak Akışkan Taşıma",
  "greate.ponder.mechanical_pump_flow.text_1": "Mekanik Pompalar bağlı oldukları boru şebekelerinin akışını yönetir",
  "greate.ponder.mechanical_pump_flow.text_2": "Üzerindeki ok, akış yönünü belirtir",
  "greate.ponder.mechanical_pump_flow.text_3": "Arkadaki şebeke akışkanı çekerken...",
  "greate.ponder.mechanical_pump_flow.text_4": "...öndeki şebeke akışkan itmektedir",
  "greate.ponder.mechanical_pump_flow.text_5": "Pompanın yönü sağlanan dönüşten etkilenmez",
  "greate.ponder.mechanical_pump_flow.text_6": "Yönünü ters çevirmek için Ayarlı Anahtar kullanılabilir",
  "greate.ponder.mechanical_pump_speed.header": "Mekanik Pompaların İletim Hızı",
  "greate.ponder.mechanical_pump_speed.text_1": "Mekanik Pompalar, hızları fark etmeksizin bağlı boruları 16 blok öteye kadar etkiler",
  "greate.ponder.mechanical_pump_speed.text_2": "Dönüşü hızlandırmak, pompalama hızını...",
  "greate.ponder.mechanical_pump_speed.text_3": "...ve akışkanların iletim hızını değiştirir",
  "greate.ponder.mechanical_pump_speed.text_4": "Aynı boru şebekesindeki pompalar iletim hızlarını birleştirebilir",
  "greate.ponder.mechanical_pump_speed.text_5": "Hepsinin aynı yönü işaret ettiğinden emin olun",
  "greate.ponder.mechanical_saw_breaker.header": "Mekanik Testereyle Ağaç Kesmek",
  "greate.ponder.mechanical_saw_breaker.text_1": "Mekanik Testere, Döndürücü Kuvvet sağlanırsa tam önündeki ağaçları keser",
  "greate.ponder.mechanical_saw_breaker.text_2": "Testerenin ağacı tamamen kesmesi için ağacın yere bağlı olan son bloğu kırması gerekir",
  "greate.ponder.mechanical_saw_contraption.header": "Mekanizmalarda Mekanik Testere Kullanımı",
  "greate.ponder.mechanical_saw_contraption.text_1": "Testereler hareketli bir Mekanizma ile beraber hareket ettiğinde...",
  "greate.ponder.mechanical_saw_contraption.text_2": "...mekanizmanın önüne gelen bütün ağaçları keserler",
  "greate.ponder.mechanical_saw_processing.header": "Malzemeleri Mekanik Testerede İşleme",
  "greate.ponder.mechanical_saw_processing.text_1": "Yukarıya bakan Mekanik Testereler çeşitli eşyaları işleyebilir",
  "greate.ponder.mechanical_saw_processing.text_2": "İşlenen eşyalar her zaman testereye verilen döndürme yönünün ters yönünde ilerler",
  "greate.ponder.mechanical_saw_processing.text_3": "Testereler, Mekanik Kayışlar ile birlikte aynı hizada çalışabilirler",
  "greate.ponder.mechanical_saw_processing.text_4": "Eğer bir ürün birden fazla sonucu olduğunda filtre yuvası bunu belirleyebilir, sınırlayabilir",
  "greate.ponder.mechanical_saw_processing.text_5": "Filtre belirlenmezse, Testere bütün sonuçlar arasında geçiş yapar",
  "greate.ponder.millstone.header": "Malzemeleri Değirmen Taşında İşleme",
  "greate.ponder.millstone.text_1": "Değirmen Taşları eşyaları öğüterek işlerler",
  "greate.ponder.millstone.text_2": "Dişliler kullanılarak yanlarından çalıştırılabilirler",
  "greate.ponder.millstone.text_3": "Üstüne eşyaları fırlatabilir ya da yerleştirebilirsiniz",
  "greate.ponder.millstone.text_4": "Üstünden biraz zaman geçince ürün sağ-tık ile elde edilebilir",
  "greate.ponder.millstone.text_5": "Ayrıca ürünler otomasyonla da alınabilir",
  "greate.ponder.shaft.header": "Şaftların dönüşsel güç aktarmak için kullanımı",
  "greate.ponder.shaft.text_1": "Şaftlar dönüşsel gücü düz bir hat boyunca aktarırlar.",
  "greate.ponder.shaft_casing.header": "Şaftları kaplama",
  "greate.ponder.shaft_casing.text_1": "Brass or Andesite Casing can be used to decorate Shafts",
