        }
    },
    {
        "apply": {"model": "tfg:block/asphalt_road/slab_overlay_arrow_south"},
        "when": {
            "color": "white|orange|magenta|light_blue|yellow|lime|pink|gray|light_gray|cyan|purple|blue|brown|green|red|black",
            "decal": "arrow_south"
        }
    },
    {
        "apply": {"model": "tfg:block/asphalt_road/slab_overlay_arrow_west"},
        "when": {
            "color": "white|orange|magenta|light_blue|yellow|lime|pink|gray|light_gray|cyan|purple|blue|brown|green|red|black",
            "decal": "arrow_west"
