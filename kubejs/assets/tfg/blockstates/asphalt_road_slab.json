{"multipart": [
    {"apply": {"model": "tfg:block/asphalt_road/slab_base"}},
    {
        "apply": {"model": "tfg:block/asphalt_road/slab_overlay_horizontal"},
        "when": {
            "color": "white|orange|magenta|light_blue|yellow|lime|pink|gray|light_gray|cyan|purple|blue|brown|green|red|black",
            "decal": "line_horizontal"
        }
    },
    {
        "apply": {"model": "tfg:block/asphalt_road/slab_overlay_vertical"},
        "when": {
            "color": "white|orange|magenta|light_blue|yellow|lime|pink|gray|light_gray|cyan|purple|blue|brown|green|red|black",
            "decal": "line_vertical"
        }
    },
    {
        "apply": {"model": "tfg:block/asphalt_road/slab_overlay_cross"},
        "when": {
            "color": "white|orange|magenta|light_blue|yellow|lime|pink|gray|light_gray|cyan|purple|blue|brown|green|red|black",
            "decal": "cross"
        }
    },
    {
        "apply": {"model": "tfg:block/asphalt_road/slab_overlay_arrow_north"},
        "when": {
            "color": "white|orange|magenta|light_blue|yellow|lime|pink|gray|light_gray|cyan|purple|blue|brown|green|red|black",
